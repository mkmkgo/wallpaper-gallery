<view class="page">
  <view class="header" style="padding-top: {{statusBarHeight}}px; height: {{statusBarHeight + navBarHeight}}px;">
    <view class="header-inner" style="height: {{navBarHeight}}px;">
      <text class="header-title">暖芯壁纸</text>
    </view>
  </view>

  <view class="collection-section" wx:if="{{collections.length > 0}}">
    <scroll-view scroll-x class="collection-scroll" enhanced show-scrollbar="{{false}}">
      <view class="collection-list">
        <view wx:for="{{collections}}" wx:key="id" class="collection-card" bindtap="onCollectionTap" data-item="{{item}}">
          <image class="collection-img" src="{{item.coverUrl}}" mode="aspectFill" lazy-load></image>
          <view class="collection-glass">
            <text class="collection-name">{{item.name}}</text>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="quick-nav">
    <scroll-view scroll-x class="quick-nav-scroll" enhanced show-scrollbar="{{false}}">
      <view class="quick-nav-list">
        <view wx:for="{{quickNav}}" wx:key="id" class="quick-nav-item" bindtap="onQuickNav" data-id="{{item.id}}">
          <view class="quick-nav-pill" style="background: {{item.color}}15; border-color: {{item.color}}30;">
            <view class="quick-nav-dot" style="background: {{item.color}};"></view>
            <text class="quick-nav-text" style="color: {{item.color}};">{{item.name}}</text>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="latest-section">
    <view class="section-header">
      <text class="section-title">最新壁纸</text>
      <view class="section-more" bindtap="navigateToLatestList">
        <text class="section-more-text">查看全部</text>
      </view>
    </view>
    <view wx:if="{{loading}}" class="skeleton-grid">
      <view wx:for="{{[1,2,3,4,5,6]}}" wx:key="*this" class="skeleton-card">
        <view class="skeleton-image shimmer"></view>
      </view>
    </view>
    <view wx:elif="{{latestWallpapers.length === 0}}" class="empty-state">
      <text class="empty-text">暂无壁纸</text>
    </view>
    <scroll-view wx:else scroll-x class="latest-scroll" enhanced show-scrollbar="{{false}}">
      <view class="latest-list">
        <view wx:for="{{latestWallpapers}}" wx:key="id" class="latest-card" bindtap="onWallpaperTap" data-item="{{item}}">
          <image class="latest-image" src="{{item.thumbnailUrl || item.previewUrl}}" mode="aspectFill" lazy-load binderror="onImageError" data-index="{{index}}" data-list="latestWallpapers"></image>
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="latest-section" wx:if="{{portraitWallpapers.length > 0}}">
    <view class="section-header">
      <text class="section-title">小姐姐</text>
      <view class="section-more" bindtap="navigateToCategory" data-name="人像">
        <text class="section-more-text">查看全部</text>
      </view>
    </view>
    <scroll-view scroll-x class="latest-scroll" enhanced show-scrollbar="{{false}}">
      <view class="latest-list">
        <view wx:for="{{portraitWallpapers}}" wx:key="id" class="latest-card" bindtap="onWallpaperTap" data-item="{{item}}">
          <image class="latest-image" src="{{item.thumbnailUrl || item.previewUrl}}" mode="aspectFill" lazy-load binderror="onImageError" data-index="{{index}}" data-list="portraitWallpapers"></image>
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="latest-section" wx:if="{{animeWallpapers.length > 0}}">
    <view class="section-header">
      <text class="section-title">卡通动漫</text>
      <view class="section-more" bindtap="navigateToCategory" data-name="动漫">
        <text class="section-more-text">查看全部</text>
      </view>
    </view>
    <scroll-view scroll-x class="latest-scroll" enhanced show-scrollbar="{{false}}">
      <view class="latest-list">
        <view wx:for="{{animeWallpapers}}" wx:key="id" class="latest-card" bindtap="onWallpaperTap" data-item="{{item}}">
          <image class="latest-image" src="{{item.thumbnailUrl || item.previewUrl}}" mode="aspectFill" lazy-load binderror="onImageError" data-index="{{index}}" data-list="animeWallpapers"></image>
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="latest-section" wx:if="{{desktopWallpapers.length > 0}}">
    <view class="section-header">
      <text class="section-title">电脑壁纸</text>
      <view class="section-more" bindtap="onQuickNav" data-id="4k">
        <text class="section-more-text">查看全部</text>
      </view>
    </view>
    <scroll-view scroll-x class="latest-scroll" enhanced show-scrollbar="{{false}}">
      <view class="desktop-list">
        <view wx:for="{{desktopWallpapers}}" wx:key="id" class="desktop-card" bindtap="onWallpaperTap" data-item="{{item}}">
          <image class="desktop-image" src="{{item.thumbnailUrl || item.previewUrl}}" mode="aspectFill" lazy-load binderror="onImageError" data-index="{{index}}" data-list="desktopWallpapers"></image>
        </view>
      </view>
    </scroll-view>
  </view>
</view>
