.page {
  background-color: #0a0a0a;
  min-height: 100vh;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 999;
  background: rgba(10, 10, 10, 0.6);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
}

.nav-bar-content {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-back {
  position: absolute;
  left: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  border-radius: 32rpx;
  background: rgba(74, 111, 165, 0.15);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

.nav-back-icon {
  width: 18rpx;
  height: 18rpx;
  border-left: 3rpx solid rgba(255, 255, 255, 0.85);
  border-bottom: 3rpx solid rgba(255, 255, 255, 0.85);
  transform: rotate(45deg);
  margin-left: 4rpx;
}

.nav-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}

.page-body {
  position: relative;
}

.loading-box {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  height: 400rpx;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.1);
  border-top-color: #667eea;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  color: #666;
  font-size: 26rpx;
}

.empty-box {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 400rpx;
}

.empty-text {
  color: #666;
  font-size: 28rpx;
}

.wallpaper-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 16rpx;
  margin: -8rpx;
}

.wallpaper-card {
  width: 50%;
  padding: 8rpx;
  box-sizing: border-box;
}

.wallpaper-image-wrap {
  position: relative;
  width: 100%;
  padding-bottom: 56.25%;
  border-radius: 16rpx;
  overflow: hidden;
  background-color: #1a1c22;
}

.wallpaper-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}
