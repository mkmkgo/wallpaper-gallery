<view class="page">
  <view class="nav-bar" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-bar-content" style="height: {{navBarHeight}}px;">
      <view class="nav-back" bindtap="goBack" style="height: {{menuButtonHeight}}px; top: {{menuButtonTop - statusBarHeight}}px;">
        <view class="nav-back-icon"></view>
      </view>
      <text class="nav-title">4K超清壁纸</text>
    </view>
  </view>

  <view class="page-body" style="padding-top: {{statusBarHeight + navBarHeight}}px;">
    <view wx:if="{{loading}}" class="loading-box">
      <view class="loading-spinner"></view>
      <text class="loading-text">加载中...</text>
    </view>

    <view wx:elif="{{wallpapers.length === 0}}" class="empty-box">
      <text class="empty-text">暂无4K壁纸</text>
    </view>

    <view wx:else class="wallpaper-grid">
      <view wx:for="{{wallpapers}}" wx:key="id" class="wallpaper-card" bindtap="onWallpaperTap" data-item="{{item}}">
        <view class="wallpaper-image-wrap">
          <image class="wallpaper-image" src="{{item.thumbnailUrl || item.previewUrl}}" mode="aspectFill" lazy-load binderror="onImageError" data-index="{{index}}"></image>
        </view>
      </view>
    </view>
  </view>
</view>
