<view class="page">
  <view class="nav-bar" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-bar-content" style="height: {{navBarHeight}}px;">
      <view class="nav-back" bindtap="goBack" style="height: {{menuButtonHeight}}px; top: {{menuButtonTop - statusBarHeight}}px;">
        <view class="nav-back-icon"></view>
      </view>
    </view>
  </view>

  <view class="page-body" style="padding-top: {{statusBarHeight + navBarHeight}}px;">
    <view wx:if="{{loading}}" class="loading-box">
      <view class="loading-spinner"></view>
      <text class="loading-text">加载中...</text>
    </view>

    <view wx:elif="{{dateGroups.length === 0}}" class="empty-box">
      <text class="empty-text">暂无壁纸</text>
    </view>

    <view wx:else>
      <scroll-view scroll-x class="date-scroll" enhanced show-scrollbar="{{false}}">
        <view class="date-list">
          <view wx:for="{{dateGroups}}" wx:key="date" class="date-item {{item.date === selectedDate ? 'date-item-active' : ''}}" bindtap="onDateTap" data-date="{{item.date}}">
            <view class="date-chip {{item.date === selectedDate ? 'date-chip-active' : ''}}">
              <text class="date-chip-text">{{item.date}}</text>
              <text class="date-chip-count">{{item.count}}张</text>
            </view>
          </view>
        </view>
      </scroll-view>

      <view class="selected-info">
        <text class="selected-date">{{selectedDate}}</text>
        <text class="selected-count">{{selectedWallpapers.length}}张壁纸</text>
      </view>

      <view class="wallpaper-grid">
        <view wx:for="{{selectedWallpapers}}" wx:key="id" class="wallpaper-card" bindtap="onWallpaperTap" data-item="{{item}}">
          <view class="wallpaper-image-wrap">
            <image class="wallpaper-image" src="{{item.thumbnailUrl || item.previewUrl}}" mode="aspectFill" lazy-load binderror="onImageError" data-item="{{item}}"></image>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
