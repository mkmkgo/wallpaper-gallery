.page {
  background-color: #0c0c0c;
  min-height: 100vh;
  padding: 24rpx 16rpx;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

.section-header {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 1rpx;
}

.category-grid {
  display: flex;
  flex-wrap: wrap;
}

.category-item {
  position: relative;
  width: 50%;
  height: 220rpx;
  padding: 8rpx;
}

.category-item:active {
  opacity: 0.85;
}

.category-bg-img {
  position: absolute;
  top: 8rpx;
  left: 8rpx;
  right: 8rpx;
  bottom: 8rpx;
  width: calc(100% - 16rpx);
  height: calc(100% - 16rpx);
  border-radius: 16rpx;
}

.category-overlay {
  position: absolute;
  top: 8rpx;
  left: 8rpx;
  right: 8rpx;
  bottom: 8rpx;
  border-radius: 16rpx;
  background: linear-gradient(180deg, rgba(0, 0, 0, 0.15) 0%, rgba(0, 0, 0, 0.65) 100%);
}

.category-info {
  position: absolute;
  bottom: 24rpx;
  left: 24rpx;
  right: 24rpx;
  display: flex;
  flex-direction: column;
  z-index: 2;
}

.category-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 2rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.5);
}

.category-count {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 4rpx;
}

.sub-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  gap: 20rpx;
}

.back-btn {
  font-size: 28rpx;
  color: #FF6B6B;
  padding: 8rpx 16rpx;
}

.sub-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 1rpx;
}

.wallpaper-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.wallpaper-card {
  width: calc(50% - 6rpx);
}

.wallpaper-image-wrap {
  position: relative;
  width: 100%;
  padding-bottom: 178%;
  border-radius: 16rpx;
  overflow: hidden;
  background-color: #1a1a1a;
}

.wallpaper-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.loading-box,
.empty-box {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  height: 400rpx;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.08);
  border-top-color: #4ECDC4;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text,
.empty-text {
  color: #444;
  font-size: 28rpx;
}

.load-more {
  display: flex;
  justify-content: center;
  padding: 40rpx 0;
}

.load-more-text {
  color: #4ECDC4;
  font-size: 26rpx;
  padding: 16rpx 56rpx;
  border: 1rpx solid rgba(78, 205, 196, 0.25);
  border-radius: 40rpx;
  background: rgba(78, 205, 196, 0.06);
}

.load-more-text:active {
  opacity: 0.7;
}

.no-more {
  display: flex;
  justify-content: center;
  padding: 40rpx 0;
}

.no-more-text {
  color: #333;
  font-size: 24rpx;
}
