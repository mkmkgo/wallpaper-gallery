<view class="tabbar-container">
  <view class="tabbar-bar">
    <view 
      class="tabbar-item {{active === 'index' ? 'active' : ''}}" 
      bindtap="switchTab" 
      data-tab="index"
    >
      <text class="tabbar-icon">🏠</text>
      <text class="tabbar-text">首页</text>
    </view>
    
    <view 
      class="tabbar-item {{active === 'category' ? 'active' : ''}}" 
      bindtap="switchTab" 
      data-tab="category"
    >
      <text class="tabbar-icon">📂</text>
      <text class="tabbar-text">分类</text>
    </view>
    
    <view 
      class="tabbar-item {{active === 'user' ? 'active' : ''}}" 
      bindtap="switchTab" 
      data-tab="user"
    >
      <text class="tabbar-icon">👤</text>
      <text class="tabbar-text">我的</text>
    </view>
  </view>
</view>