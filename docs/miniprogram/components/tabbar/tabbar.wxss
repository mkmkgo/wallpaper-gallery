/* 容器 */
.tabbar-container {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 999;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
}

/* 磨砂玻璃导航栏 - 透明磨砂效果 */
.tabbar-bar {
  display: flex;
  justify-content: space-around;
  align-items: center;
  margin: 0 80rpx 16rpx 80rpx;
  padding: 8rpx 12rpx;
  background: rgba(255, 255, 255, 0.5);
  backdrop-filter: blur(30px);
  -webkit-backdrop-filter: blur(30px);
  border-radius: 50rpx;
  border: 1px solid rgba(255, 255, 255, 0.6);
  box-shadow: 0 6rpx 24rpx rgba(0, 0, 0, 0.08);
}

/* 导航项 */
.tabbar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 4rpx 12rpx;
  background: transparent;
  border-radius: 16rpx;
  transition: all 0.3s ease;
}

/* 导航图标 */
.tabbar-icon {
  font-size: 28rpx;
  margin-bottom: 2rpx;
  opacity: 0.4;
  transition: all 0.3s ease;
}

/* 导航文字 */
.tabbar-text {
  font-size: 16rpx;
  color: #888888;
  font-weight: 500;
  transition: all 0.3s ease;
}

/* 选中状态 */
.tabbar-item.active {
  background: rgba(102, 126, 234, 0.08);
}

.tabbar-item.active .tabbar-icon {
  opacity: 1;
  transform: scale(1.05);
}

.tabbar-item.active .tabbar-text {
  color: #667eea;
  font-weight: 600;
}

/* 按钮点击效果 */
.tabbar-item:active {
  opacity: 0.7;
  transform: scale(0.95);
}