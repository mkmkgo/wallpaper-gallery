<view class="container">
  <!-- 背景图片 -->
  <view class="page-background">
    <image src="https://tp.202597.xyz/file/1776619327721_%E5%9B%BE%E7%89%87.png" mode="aspectFill" class="bg-image"/>
    <view class="bg-blur"></view>
  </view>
  
  <!-- 内容层 -->
  <view class="page-content">
    <view class="user-info">
      <view class="user-avatar">
        <image src="/images/avatar-default.png" mode="aspectFill"/>
      </view>
      <view class="user-details">
        <view class="user-name">游客用户</view>
        <view class="user-id">未登录</view>
      </view>
    </view>

    <view class="function-list">
      <view class="function-item" bindtap="goToDownloadHistory">
        <text class="function-text">下载历史</text>
        <text class="function-arrow">›</text>
      </view>
      <view class="function-item" bindtap="goToFavorites">
        <text class="function-text">我的收藏</text>
        <text class="function-arrow">›</text>
      </view>
      <view class="function-item" bindtap="goToAdHistory">
        <text class="function-text">广告历史</text>
        <text class="function-arrow">›</text>
      </view>
      <view class="function-item" bindtap="goToAbout">
        <text class="function-text">关于我们</text>
        <text class="function-arrow">›</text>
      </view>
    </view>

    <view class="version-info">
      版本 1.0.0
    </view>
  </view>

  <!-- 自定义磨砂玻璃tabBar -->
  <tabbar active="user"></tabbar>
</view>