/* 用户页容器 */
.container {
  min-height: 100vh;
  padding-bottom: 140rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  position: relative;
}

/* 背景图片容器 */
.page-background {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 0;
}

/* 背景图片 */
.bg-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* 背景模糊层 */
.bg-blur {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.3);
  backdrop-filter: blur(3px);
  -webkit-backdrop-filter: blur(3px);
}

/* 内容层 */
.page-content {
  position: relative;
  z-index: 1;
}

.user-info {
  display: flex;
  align-items: center;
  padding: 32rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 12rpx;
  margin-bottom: 24rpx;
  border: 1px solid rgba(255, 255, 255, 0.2);
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  overflow: hidden;
  margin-right: 24rpx;
  background-color: rgba(255, 255, 255, 0.2);
}

.user-details {
  flex: 1;
}

.user-name {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
  color: #ffffff;
}

.user-id {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.function-list {
  background: rgba(255, 255, 255, 0.15);
  border-radius: 12rpx;
  margin-bottom: 24rpx;
  border: 1px solid rgba(255, 255, 255, 0.2);
}

.function-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}

.function-item:last-child {
  border-bottom: none;
}

.function-text {
  font-size: 28rpx;
  color: #ffffff;
}

.function-arrow {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.7);
}

.version-info {
  text-align: center;
  color: rgba(255, 255, 255, 0.7);
  font-size: 24rpx;
  padding: 24rpx;
}