/* 全屏容器 */
.container {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  overflow: hidden;
}

/* 全屏背景图片 - 正好平铺整个屏幕 */
.full-screen-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
}

/* 磨砂玻璃按钮栏 */
.glass-bar {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(0, 0, 0, 0.4);
  backdrop-filter: blur(30px);
  -webkit-backdrop-filter: blur(30px);
  border-top: 1px solid rgba(255, 255, 255, 0.2);
  z-index: 2;
}

/* 磨砂玻璃按钮 */
.glass-button {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 140rpx;
  height: 110rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border: 1px solid rgba(255, 255, 255, 0.25);
  transition: all 0.3s ease;
}

.glass-button:active {
  transform: scale(0.95);
  background: rgba(255, 255, 255, 0.25);
}

/* 返回按钮 - 更宽一些 */
.back-button {
  width: 150rpx;
  background: rgba(255, 255, 255, 0.2);
}

/* 分享按钮 - 更突出 */
.share-button {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 140rpx;
  height: 110rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 16rpx;
  box-shadow: 0 6rpx 16rpx rgba(102, 126, 234, 0.4);
  border: 1px solid rgba(255, 255, 255, 0.3);
  transition: all 0.3s ease;
}

.share-button:active {
  transform: scale(0.95);
  box-shadow: 0 3rpx 8rpx rgba(102, 126, 234, 0.3);
}

/* 按钮图标 */
.button-icon {
  font-size: 40rpx;
  margin-bottom: 6rpx;
  color: white;
}

/* 按钮文字 */
.button-text {
  font-size: 22rpx;
  color: white;
  font-weight: 500;
}

/* 真机预览弹窗 */
.preview-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

/* 预览内容 */
.preview-content {
  width: 80%;
  max-width: 400rpx;
  background: white;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.5);
}

/* 预览头部 */
.preview-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background: #f8f8f8;
  border-bottom: 1rpx solid #eee;
}

/* 预览标题 */
.preview-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

/* 关闭按钮 */
.preview-close {
  font-size: 36rpx;
  color: #999;
  padding: 8rpx 16rpx;
}

/* 设备框架 */
.device-frame {
  width: 100%;
  padding: 40rpx;
  background: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 设备屏幕 */
.device-screen {
  width: 260rpx;
  height: 520rpx;
  border-radius: 40rpx;
  overflow: hidden;
  box-shadow: inset 0 0 15rpx rgba(0, 0, 0, 0.2);
  background: #000;
  border: 3rpx solid #333;
}

/* 设备图片 */
.device-image {
  width: 100%;
  height: 100%;
}
