/* 首页容器 */
.container {
  min-height: 100vh;
  padding-top: calc(env(safe-area-inset-top) + 80px);
  padding-bottom: 140rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  position: relative;
}

/* 背景图片容器 */
.page-background {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 0;
}

/* 背景图片 */
.bg-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* 背景模糊层 */
.bg-blur {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.3);
  backdrop-filter: blur(3px);
  -webkit-backdrop-filter: blur(3px);
}

/* 内容层 */
.page-content {
  position: relative;
  z-index: 1;
}

.swipe {
  height: 400rpx;
}

.swipe-image {
  width: 100%;
  height: 100%;
}

.swipe-info {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(transparent, rgba(0,0,0,0.7));
  padding: 24rpx;
  color: white;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.view-more {
  font-size: 24rpx;
  color: #ffffff;
}

.horizontal-scroll {
  width: 100%;
  white-space: nowrap;
}

.wallpaper-row {
  display: inline-flex;
  flex-direction: row;
  align-items: flex-start;
}

.wallpaper-card {
  width: 320rpx;
  height: 569rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  border: 1px solid rgba(255, 255, 255, 0.2);
}

.wallpaper-image {
  width: 100%;
  height: 100%;
  display: block;
}

.wallpaper-info {
  padding: 16rpx;
}

.wallpaper-title {
  font-size: 24rpx;
  color: #ffffff;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.category-scroll {
  white-space: nowrap;
  margin-bottom: 24rpx;
}

.category-list {
  display: inline-flex;
  gap: 16rpx;
  padding: 0 16rpx;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.category-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  overflow: hidden;
}

.category-name {
  font-size: 24rpx;
  color: #ffffff;
  text-align: center;
  margin-top: 8rpx;
  max-width: 120rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.hot-buttons {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.hot-button {
  background: rgba(255, 255, 255, 0.15);
  border-radius: 12rpx;
  padding: 32rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  transition: transform 0.2s ease;
  cursor: pointer;
  min-height: 160rpx;
  justify-content: center;
  border: 1px solid rgba(255, 255, 255, 0.2);
}

.hot-button:active {
  transform: scale(0.95);
}

.hot-button-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.hot-button-text {
  font-size: 20rpx;
  color: #ffffff;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.loading {
  text-align: center;
  padding: 40rpx;
  color: #999;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 24rpx;
}