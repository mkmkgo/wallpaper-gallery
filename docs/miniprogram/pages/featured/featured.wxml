<view class="container">
  <view class="section-title">精选壁纸</view>

  <view class="wallpaper-grid">
    <view class="wallpaper-card" wx:for="{{displayWallpapers}}" wx:key="{{item.id}}" bindtap="goToDetail" data-wallpaper="{{item}}">
      <image src="{{item.thumbnailUrl}}" mode="aspectFill" class="wallpaper-image"/>
      <view class="wallpaper-info">
        <view class="wallpaper-title">{{item.title}}</view>
      </view>
    </view>
  </view>

  <view wx:if="{{isLoading}}" class="loading">
    <text>加载中...</text>
  </view>

  <view wx:if="{{!isLoading && hasMore}}" class="load-more" bindtap="loadMore">
    加载更多
  </view>

  <view wx:if="{{!isLoading && !hasMore}}" class="no-more">
    没有更多了
  </view>
</view>