.wallpaper-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.wallpaper-card {
  width: 100%;
  aspect-ratio: 9/16;
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.wallpaper-image {
  width: 100%;
  height: 100%;
  display: block;
}

.wallpaper-info {
  padding: 16rpx;
}

.wallpaper-title {
  font-size: 24rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.load-more,
.no-more {
  text-align: center;
  padding: 24rpx;
  color: #667eea;
  font-size: 28rpx;
}

.no-more {
  color: #999;
}