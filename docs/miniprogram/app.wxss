page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
}

.container {
  padding: 16rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  margin: 24rpx 0;
  color: #333;
}

.wallpaper-card {
  border-radius: 12rpx;
  overflow: hidden;
  background: white;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  margin-bottom: 16rpx;
}

.wallpaper-image {
  width: 100%;
  height: 400rpx;
  object-fit: cover;
}

.wallpaper-info {
  padding: 16rpx;
}

.wallpaper-title {
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
  color: #333;
}

.wallpaper-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 8rpx;
}

.tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  background-color: #f0f0f0;
  border-radius: 16rpx;
  color: #666;
}

.btn {
  display: block;
  width: 100%;
  padding: 16rpx;
  text-align: center;
  border-radius: 8rpx;
  font-size: 28rpx;
  font-weight: bold;
  margin-top: 16rpx;
}

.btn-primary {
  background-color: #667eea;
  color: white;
}

.btn-secondary {
  background-color: #f0f0f0;
  color: #333;
}

.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40rpx;
}

.empty {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 80rpx 0;
  color: #999;
}

.view-more {
  text-align: center;
  padding: 16rpx;
  color: #667eea;
  font-size: 28rpx;
}

.detail-image {
  width: 100%;
  height: 600rpx;
  object-fit: contain;
  background-color: #f0f0f0;
}

.device-preview {
  margin: 24rpx 0;
  padding: 24rpx;
  background: white;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.device-preview-title {
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
  color: #333;
}

.device-frame {
  position: relative;
  width: 280rpx;
  height: 560rpx;
  margin: 0 auto;
  background: black;
  border-radius: 40rpx;
  padding: 20rpx;
  box-sizing: border-box;
}

.device-screen {
  width: 100%;
  height: 100%;
  border-radius: 20rpx;
  overflow: hidden;
}

.device-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}