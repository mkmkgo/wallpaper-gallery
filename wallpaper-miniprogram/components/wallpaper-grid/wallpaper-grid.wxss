.wallpaper-grid-wrapper {
  width: 100%;
}

.loading-box {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  height: 400rpx;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.1);
  border-top-color: #ff4757;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  color: #666;
  font-size: 26rpx;
}

.empty-box {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 400rpx;
}

.empty-text {
  color: #666;
  font-size: 28rpx;
}

.wallpaper-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 0 12rpx;
}

.wallpaper-card {
  width: 50%;
  padding: 8rpx;
  box-sizing: border-box;
}

.wallpaper-image-wrap {
  position: relative;
  width: 100%;
  padding-bottom: 178%;
  border-radius: 16rpx;
  overflow: hidden;
  background-color: #1a1a1a;
}

.wallpaper-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.hot-rank {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  min-width: 40rpx;
  height: 40rpx;
  border-radius: 12rpx;
  background: rgba(0, 0, 0, 0.6);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 10rpx;
}

.rank-text {
  font-size: 22rpx;
  font-weight: bold;
  color: #fff;
}

.load-more {
  display: flex;
  justify-content: center;
  padding: 40rpx 0;
}

.load-more-text {
  color: #ff4757;
  font-size: 28rpx;
  padding: 16rpx 60rpx;
  border: 1rpx solid rgba(255, 71, 87, 0.3);
  border-radius: 40rpx;
  background: rgba(255, 71, 87, 0.08);
}

.no-more {
  display: flex;
  justify-content: center;
  padding: 40rpx 0;
}

.no-more-text {
  color: #444;
  font-size: 24rpx;
}
