<view class="wallpaper-grid-wrapper">
  <view wx:if="{{loading}}" class="loading-box">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <view wx:elif="{{wallpapers.length === 0}}" class="empty-box">
    <text class="empty-text">暂无壁纸</text>
  </view>

  <view wx:else class="wallpaper-grid">
    <view wx:for="{{wallpapers}}" wx:key="id" class="wallpaper-card" bindtap="onWallpaperTap" data-item="{{item}}">
      <view class="wallpaper-image-wrap">
        <image class="wallpaper-image" src="{{item.thumbnailUrl || item.previewUrl}}" mode="aspectFill" lazy-load binderror="onImageError" data-index="{{index}}"></image>
        <view class="hot-rank" wx:if="{{showRank && index < 50}}">
          <text class="rank-text">{{index + 1}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="load-more" wx:if="{{!loading && wallpapers.length > 0 && hasMore}}">
    <text class="load-more-text" bindtap="onLoadMore">加载更多</text>
  </view>

  <view class="no-more" wx:if="{{!loading && wallpapers.length > 0 && !hasMore}}">
    <text class="no-more-text">— 已经到底了 —</text>
  </view>
</view>
