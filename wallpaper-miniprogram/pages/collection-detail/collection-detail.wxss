.page {
  background-color: #0c0c0c;
  min-height: 100vh;
}

.nav-bar {
  position: sticky;
  top: 0;
  z-index: 100;
  background: rgba(12, 12, 12, 0.92);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
}

.nav-bar-inner {
  display: flex;
  align-items: center;
  padding: 0 32rpx;
}

.nav-back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-back-arrow {
  width: 18rpx;
  height: 18rpx;
  border-left: 3rpx solid #fff;
  border-bottom: 3rpx solid #fff;
  transform: rotate(45deg);
}

.nav-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
  margin-left: 8rpx;
  letter-spacing: 1rpx;
}

.loading-box,
.empty-box {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  height: 400rpx;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.08);
  border-top-color: #4ECDC4;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text,
.empty-text {
  color: #444;
  font-size: 28rpx;
}

.wallpaper-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  padding: 12rpx 24rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.wallpaper-card {
  width: calc(50% - 6rpx);
}

.wallpaper-image-wrap {
  position: relative;
  width: 100%;
  padding-bottom: 178%;
  border-radius: 16rpx;
  overflow: hidden;
  background-color: #1a1a1a;
}

.wallpaper-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}
