.page {
  background-color: #0c0c0c;
  min-height: 100vh;
  padding: 32rpx;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

.section-header {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 1rpx;
}

.category-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.category-item {
  width: calc(50% - 8rpx);
}

.category-box {
  position: relative;
  height: 140rpx;
  border-radius: 20rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 0 28rpx;
}

.category-box:active {
  opacity: 0.85;
}

.category-item:nth-child(6n+1) .category-box {
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
}

.category-item:nth-child(6n+2) .category-box {
  background: linear-gradient(135deg, #1a2a1a 0%, #1e3a2e 50%, #0d4d2e 100%);
}

.category-item:nth-child(6n+3) .category-box {
  background: linear-gradient(135deg, #2a1a1a 0%, #3e1621 50%, #600f2e 100%);
}

.category-item:nth-child(6n+4) .category-box {
  background: linear-gradient(135deg, #2a1a2e 0%, #3e1640 50%, #580f60 100%);
}

.category-item:nth-child(6n+5) .category-box {
  background: linear-gradient(135deg, #1a2a2e 0%, #163e3e 50%, #0f6060 100%);
}

.category-item:nth-child(6n+6) .category-box {
  background: linear-gradient(135deg, #2e2a1a 0%, #3e3616 50%, #60500f 100%);
}

.category-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
  letter-spacing: 2rpx;
}

.sub-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  gap: 20rpx;
}

.back-btn {
  font-size: 28rpx;
  color: #FF6B6B;
  padding: 8rpx 16rpx;
}

.sub-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 1rpx;
}

.wallpaper-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.wallpaper-card {
  width: calc(50% - 8rpx);
}

.wallpaper-image-wrap {
  position: relative;
  width: 100%;
  padding-bottom: 178%;
  border-radius: 20rpx;
  overflow: hidden;
  background-color: #1a1a1a;
}

.wallpaper-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.loading-box,
.empty-box {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  height: 400rpx;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.08);
  border-top-color: #4ECDC4;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text,
.empty-text {
  color: #444;
  font-size: 28rpx;
}

.load-more {
  display: flex;
  justify-content: center;
  padding: 40rpx 0;
}

.load-more-text {
  color: #4ECDC4;
  font-size: 26rpx;
  padding: 16rpx 56rpx;
  border: 1rpx solid rgba(78, 205, 196, 0.25);
  border-radius: 40rpx;
  background: rgba(78, 205, 196, 0.06);
}

.load-more-text:active {
  opacity: 0.7;
}

.no-more {
  display: flex;
  justify-content: center;
  padding: 40rpx 0;
}

.no-more-text {
  color: #333;
  font-size: 24rpx;
}
