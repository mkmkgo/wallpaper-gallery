.page {
  background-color: #0a0a0a;
  min-height: 100vh;
  padding: 20rpx;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

.section-header {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #fff;
}

.category-grid {
  display: flex;
  flex-wrap: wrap;
  margin: -8rpx;
}

.category-item {
  width: 25%;
  padding: 8rpx;
  box-sizing: border-box;
}

.category-box {
  background: linear-gradient(135deg, #2d1b69 0%, #11998e 100%);
  border-radius: 16rpx;
  padding: 28rpx 10rpx;
  text-align: center;
}

.category-text {
  font-size: 24rpx;
  color: #fff;
}

.sub-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.back-btn {
  font-size: 28rpx;
  color: #ff4757;
  margin-right: 20rpx;
}

.sub-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
}

.wallpaper-grid {
  display: flex;
  flex-wrap: wrap;
  margin: -5rpx;
}

.wallpaper-card {
  width: 25%;
  padding: 5rpx;
  box-sizing: border-box;
}

.wallpaper-image {
  width: 100%;
  height: 280rpx;
  border-radius: 8rpx;
  background-color: #1a1a1a;
}

.loading-box,
.empty-box {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 400rpx;
}

.loading-text,
.empty-text {
  color: #666;
  font-size: 28rpx;
}

.pagination {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 30rpx 0;
}

.page-btn {
  padding: 16rpx 36rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 30rpx;
  font-size: 26rpx;
}

.page-btn.disabled {
  opacity: 0.4;
}

.page-info {
  color: #999;
  font-size: 26rpx;
  margin: 0 30rpx;
}
