.page {
  background-color: #0a0a0a;
  min-height: 100vh;
  padding: 20rpx;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

.section-header {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #fff;
}

.date-scroll {
  white-space: nowrap;
  margin-bottom: 20rpx;
}

.date-list {
  display: inline-flex;
  padding: 10rpx 0;
}

.date-item {
  display: inline-block;
  margin-right: 16rpx;
}

.date-box {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 16rpx;
  padding: 16rpx 24rpx;
  text-align: center;
  min-width: 140rpx;
}

.date-text {
  display: block;
  font-size: 24rpx;
  color: #fff;
  margin-bottom: 4rpx;
}

.date-count {
  display: block;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.7);
}

.date-group {
  margin-bottom: 30rpx;
}

.date-group-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  padding: 10rpx 0;
}

.date-group-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #fff;
}

.date-group-count {
  font-size: 24rpx;
  color: #ff4757;
}

.wallpaper-grid {
  display: flex;
  flex-wrap: wrap;
  margin: -5rpx;
}

.wallpaper-card {
  width: 33.333%;
  padding: 5rpx;
  box-sizing: border-box;
}

.wallpaper-image {
  width: 100%;
  height: 300rpx;
  border-radius: 8rpx;
  background-color: #1a1a1a;
}

.loading-box,
.empty-box {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 400rpx;
}

.loading-text,
.empty-text {
  color: #666;
  font-size: 28rpx;
}
