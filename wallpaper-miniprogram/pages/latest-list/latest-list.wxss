.page {
  background-color: #0a0a0a;
  min-height: 100vh;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 999;
  background: rgba(10, 10, 10, 0.6);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
}

.nav-bar-content {
  position: relative;
  display: flex;
  align-items: center;
}

.nav-back {
  position: absolute;
  left: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

.nav-back-icon {
  width: 18rpx;
  height: 18rpx;
  border-left: 3rpx solid rgba(255, 255, 255, 0.85);
  border-bottom: 3rpx solid rgba(255, 255, 255, 0.85);
  transform: rotate(45deg);
  margin-left: 4rpx;
}

.page-body {
  position: relative;
}

.loading-box {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  height: 400rpx;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.1);
  border-top-color: #667eea;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  color: #666;
  font-size: 26rpx;
}

.empty-box {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 400rpx;
}

.empty-text {
  color: #666;
  font-size: 28rpx;
}

.date-scroll {
  white-space: nowrap;
  padding: 10rpx 30rpx 20rpx;
}

.date-list {
  display: inline-flex;
  gap: 16rpx;
}

.date-item {
  display: inline-block;
}

.date-chip {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 28rpx;
  border-radius: 20rpx;
  background: rgba(102, 126, 234, 0.1);
  border: 1rpx solid rgba(102, 126, 234, 0.2);
  min-width: 140rpx;
}

.date-chip-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 4rpx;
}

.date-chip-count {
  font-size: 20rpx;
  color: rgba(102, 126, 234, 0.8);
}

.wallpaper-list {
  padding: 0 30rpx;
}

.date-group {
  margin-bottom: 36rpx;
}

.date-group-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  padding: 12rpx 0;
}

.date-group-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.date-group-line {
  width: 6rpx;
  height: 28rpx;
  border-radius: 3rpx;
  background: linear-gradient(180deg, #667eea 0%, #764ba2 100%);
}

.date-group-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #fff;
}

.date-group-right {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.date-group-count {
  font-size: 24rpx;
  color: #666;
}

.date-group-arrow {
  width: 12rpx;
  height: 12rpx;
  border-top: 2rpx solid #666;
  border-right: 2rpx solid #666;
  transform: rotate(45deg);
}

.wallpaper-grid {
  display: flex;
  flex-wrap: wrap;
  margin: -8rpx;
}

.wallpaper-card {
  width: 50%;
  padding: 8rpx;
  box-sizing: border-box;
}

.wallpaper-image-wrap {
  position: relative;
  width: 100%;
  padding-bottom: 178%;
  border-radius: 16rpx;
  overflow: hidden;
  background-color: #1a1a1a;
}

.wallpaper-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}
