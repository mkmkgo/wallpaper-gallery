<view class="page">
  <view class="nav-bar" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-bar-content" style="height: {{navBarHeight}}px;">
      <view class="nav-back" bindtap="goBack" style="height: {{menuButtonHeight}}px; top: {{menuButtonTop - statusBarHeight}}px;">
        <view class="nav-back-icon"></view>
      </view>
    </view>
  </view>

  <view class="page-body" style="padding-top: {{statusBarHeight + navBarHeight}}px;">
    <view wx:if="{{loading}}" class="loading-box">
      <view class="loading-spinner"></view>
      <text class="loading-text">加载中...</text>
    </view>

    <view wx:elif="{{dateGroups.length === 0}}" class="empty-box">
      <text class="empty-text">暂无壁纸</text>
    </view>

    <view wx:else>
      <scroll-view scroll-x class="date-scroll" enhanced show-scrollbar="{{false}}">
        <view class="date-list">
          <view wx:for="{{dateGroups}}" wx:key="date" class="date-item" bindtap="onDateTap" data-date="{{item.date}}">
            <view class="date-chip">
              <text class="date-chip-text">{{item.date}}</text>
              <text class="date-chip-count">{{item.count}}张</text>
            </view>
          </view>
        </view>
      </scroll-view>

      <view class="wallpaper-list">
        <block wx:for="{{dateGroups}}" wx:key="date">
          <view class="date-group">
            <view class="date-group-header" bindtap="onDateTap" data-date="{{item.date}}">
              <view class="date-group-left">
                <view class="date-group-line"></view>
                <text class="date-group-title">{{item.date}}</text>
              </view>
              <view class="date-group-right">
                <text class="date-group-count">{{item.count}}张</text>
                <view class="date-group-arrow"></view>
              </view>
            </view>
            <view class="wallpaper-grid">
              <view wx:for="{{item.wallpapers}}" wx:for-item="wp" wx:key="id" class="wallpaper-card" bindtap="onWallpaperTap" data-item="{{wp}}">
                <view class="wallpaper-image-wrap">
                  <image class="wallpaper-image" src="{{wp.thumbnailUrl || wp.previewUrl}}" mode="aspectFill" lazy-load binderror="onImageError" data-item="{{wp}}"></image>
                </view>
              </view>
            </view>
          </view>
        </block>
      </view>
    </view>
  </view>
</view>
