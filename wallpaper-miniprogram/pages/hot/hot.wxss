.page {
  background-color: #0a0a0a;
  min-height: 100vh;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 999;
  background: rgba(10, 10, 10, 0.6);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
}

.nav-bar-content {
  position: relative;
  display: flex;
  align-items: center;
}

.nav-back {
  position: absolute;
  left: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

.nav-back-icon {
  width: 18rpx;
  height: 18rpx;
  border-left: 3rpx solid rgba(255, 255, 255, 0.85);
  border-bottom: 3rpx solid rgba(255, 255, 255, 0.85);
  transform: rotate(45deg);
  margin-left: 4rpx;
}

.page-body {
  position: relative;
}
