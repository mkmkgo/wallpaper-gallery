<view class="page">
  <view class="collections-section" style="padding-top: {{statusBarHeight + navBarHeight}}px;">
    <scroll-view scroll-x class="collections-scroll" enhanced show-scrollbar="{{false}}">
      <view class="collections-list">
        <view wx:for="{{collections}}" wx:key="id" class="collection-item" bindtap="onCollectionTap" data-id="{{item.id}}">
          <view class="collection-card collection-card-{{item.id}}">
            <view class="collection-glow collection-glow-{{item.id}}"></view>
            <view class="collection-icon-wrap">
              <view class="collection-icon-inner collection-icon-{{item.id}}"></view>
            </view>
            <text class="collection-name">{{item.name}}</text>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="nav-section">
    <view class="nav-grid">
      <view wx:for="{{navButtons}}" wx:key="id" class="nav-item" bindtap="onNavTap" data-id="{{item.id}}">
        <view class="nav-icon-wrap nav-icon-{{item.id}}">
          <view class="nav-icon-inner"></view>
        </view>
        <text class="nav-name">{{item.name}}</text>
      </view>
    </view>
  </view>

  <view class="category-section" wx:if="{{categories.length > 0}}">
    <view class="section-header">
      <view class="section-title-wrap">
        <view class="section-title-dot"></view>
        <text class="section-title">热门分类</text>
      </view>
      <view class="section-more-btn" bindtap="onCategoryMore">
        <text class="section-more-text">更多</text>
        <view class="section-more-arrow"></view>
      </view>
    </view>
    <view class="category-grid">
      <view wx:for="{{categories}}" wx:key="name" class="category-item" bindtap="onCategoryTap" data-name="{{item.name}}">
        <view class="category-box">
          <text class="category-text">{{item.name}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="latest-section">
    <view class="section-header">
      <view class="section-title-wrap">
        <view class="section-title-dot section-title-dot-blue"></view>
        <text class="section-title">最新壁纸</text>
      </view>
      <view class="section-more-btn" bindtap="navigateToLatestList">
        <text class="section-more-text">更多</text>
        <view class="section-more-arrow"></view>
      </view>
    </view>
    <view wx:if="{{loading}}" class="loading-box">
      <text class="loading-text">加载中...</text>
    </view>
    <view wx:elif="{{latestWallpapers.length === 0}}" class="empty-box">
      <text class="empty-text">暂无壁纸</text>
    </view>
    <scroll-view wx:else scroll-x class="latest-scroll" enhanced show-scrollbar="{{false}}">
      <view class="latest-scroll-list">
        <view wx:for="{{latestWallpapers}}" wx:key="id" class="latest-card" bindtap="onWallpaperTap" data-item="{{item}}">
          <view class="latest-image-wrap">
            <image class="latest-image" src="{{item.thumbnailUrl || item.previewUrl}}" mode="aspectFill" lazy-load binderror="onImageError" data-index="{{index}}" data-list="latestWallpapers"></image>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>
</view>
