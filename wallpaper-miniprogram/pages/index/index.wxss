page {
  background-color: #0c0c0c;
  color: #fff;
  font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", "PingFang SC", "Helvetica Neue", sans-serif;
  font-size: 28rpx;
  box-sizing: border-box;
  -webkit-font-smoothing: antialiased;
}

view, text, image, scroll-view {
  box-sizing: border-box;
}

image {
  background-color: #1a1a1a;
}

.page {
  background-color: #0c0c0c;
  min-height: 100vh;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

.header {
  padding: 0 32rpx 28rpx;
  background: linear-gradient(180deg, #151520 0%, #0c0c0c 100%);
}

.header-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.header-left {
  display: flex;
  flex-direction: column;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
  background: linear-gradient(135deg, #fff 0%, #a0a0b0 100%);
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
}

.header-sub {
  font-size: 22rpx;
  color: #666;
  margin-top: 4rpx;
  letter-spacing: 2rpx;
}

.quick-nav {
  padding: 0 32rpx 24rpx;
}

.quick-nav-scroll {
  white-space: nowrap;
}

.quick-nav-list {
  display: inline-flex;
  gap: 16rpx;
}

.quick-nav-item {
  display: inline-flex;
}

.quick-nav-pill {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 14rpx 28rpx;
  border-radius: 40rpx;
  border: 1rpx solid;
  transition: opacity 0.2s;
}

.quick-nav-pill:active {
  opacity: 0.7;
}

.quick-nav-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.quick-nav-text {
  font-size: 26rpx;
  font-weight: 500;
  white-space: nowrap;
}

.collection-section {
  padding: 0 32rpx 28rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 1rpx;
}

.section-more {
  padding: 8rpx 0;
}

.section-more-text {
  font-size: 24rpx;
  color: #666;
}

.collection-scroll {
  white-space: nowrap;
  margin: 0 -32rpx;
  padding: 0 32rpx;
}

.collection-list {
  display: inline-flex;
  gap: 20rpx;
}

.collection-card {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  width: 200rpx;
  flex-shrink: 0;
}

.collection-card:active {
  opacity: 0.8;
}

.collection-cover-wrap {
  position: relative;
  width: 200rpx;
  height: 260rpx;
  border-radius: 20rpx;
  overflow: hidden;
}

.collection-cover {
  width: 100%;
  height: 100%;
}

.collection-cover-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 80rpx;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.5));
}

.collection-name {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 12rpx;
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 200rpx;
  font-weight: 500;
}

.latest-section {
  padding: 0 32rpx 32rpx;
}

.skeleton-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.skeleton-card {
  width: calc(33.33% - 12rpx);
}

.skeleton-image {
  width: 100%;
  height: 360rpx;
  border-radius: 16rpx;
  background-color: #1a1a1a;
}

.shimmer {
  background: linear-gradient(90deg, #1a1a1a 25%, #222 50%, #1a1a1a 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s ease-in-out infinite;
}

@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

.empty-state {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 300rpx;
}

.empty-text {
  color: #444;
  font-size: 28rpx;
}

.latest-scroll {
  white-space: nowrap;
  margin: 0 -32rpx;
  padding: 0 32rpx;
}

.latest-list {
  display: inline-flex;
  gap: 16rpx;
}

.latest-card {
  display: inline-flex;
  width: 240rpx;
  height: 420rpx;
  border-radius: 20rpx;
  overflow: hidden;
  flex-shrink: 0;
}

.latest-card:active {
  opacity: 0.85;
}

.latest-image {
  width: 100%;
  height: 100%;
}
